<Window x:Class="Users_Klimov.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Users_Klimov"
        mc:Ignorable="d"
        Title="Пользователи и роли в системе управления" Height="450" Width="800" MinHeight="450" MinWidth="800">

    <Grid Background="#F0F0F0">
        <Grid Height="50" VerticalAlignment="Top" Background="White">
            <Grid.Effect>
                <DropShadowEffect Opacity="0.1"/>
            </Grid.Effect>
            <Image Width="30" Height="30" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10"
                   Source="/Images/ic_users.png" MouseDown="ToUsers"/>
            <Label Content="Пользователи и роли в системе управления"
                   VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                   FontSize="18" HorizontalAlignment="Center"/>
            <Image Width="30" Height="30" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="10"
                   Source="/Images/ic_roles.png" MouseDown="ToRoles"/>
        </Grid>
        <Frame x:Name="frame" NavigationUIVisibility="Hidden" Margin="0,55,0,0"/>
    </Grid>
</Window>
