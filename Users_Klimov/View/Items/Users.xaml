<UserControl x:Class="Users_Klimov.View.Items.Users"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Users_Klimov.View.Items"
             mc:Ignorable="d"
             FontFamily="Bahnschrift">

    <UserControl.Resources>
        <Style TargetType="Button" x:Key="Update">
            <Setter Property="Background" Value="#FF2DD618"/>
            <Setter Property="BorderBrush" Value="#FF2DD618"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="Button" x:Key="Delete">
            <Setter Property="Background" Value="#FFD62F1B"/>
            <Setter Property="BorderBrush" Value="#FFD62F1B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10" Background="White">
        <Grid.Effect>
            <DropShadowEffect Opacity="0.1"/>
        </Grid.Effect>
        <Image Width="40" Height="40" Margin="10" VerticalAlignment="Top" HorizontalAlignment="Left"
               Source="/Images/ic_user.png"/>
        <Grid Margin="60,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid Margin="10" Height="60" VerticalAlignment="Top" Background="White">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Имя:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                <TextBox
                Text="{Binding Firstname}"
                IsEnabled="{Binding IsEnable}"
                VerticalContentAlignment="Center"
                Margin="10,25,10,0"
                VerticalAlignment="Top"
                Height="25"/>
            </Grid>
            <Grid Margin="10,80,10,0" Height="60" VerticalAlignment="Top" Background="White" Grid.ColumnSpan="2">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="E-Mail:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                <TextBox
                    Text="{Binding Email}"
                    IsEnabled="{Binding IsEnable}"
                    VerticalContentAlignment="Center"
                    Margin="10,25,10,0"
                    VerticalAlignment="Top"
                    Height="25"/>
            </Grid>
            <Grid Margin="10,10,10,10" Height="60" VerticalAlignment="Top" Background="White" Grid.Column="1">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Фамилия:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                <TextBox
                    Text="{Binding Surname}"
                    IsEnabled="{Binding IsEnable}"
                    VerticalContentAlignment="Center"
                    Margin="10,25,10,0"
                    VerticalAlignment="Top"
                    Height="25"/>
            </Grid>
            <Grid Margin="10,150,10,10" Height="60" VerticalAlignment="Top" Background="White" Grid.ColumnSpan="2">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Роль:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                <ComboBox
                    DisplayMemberPath="Role"
                    SelectedValuePath="Id"
                    SelectedValue="{Binding RoleId, UpdateSourceTrigger=PropertyChanged}"
                    ItemsSource="{Binding AllRoles}"
                    IsEnabled="{Binding IsEnable}"
                    VerticalContentAlignment="Center"
                    Margin="10,25,10,0"
                    VerticalAlignment="Top"
                    Height="25"/>
            </Grid>
            <Button Style="{StaticResource Update}"
                    Command="{Binding OnEdit}"
                    Content="{Binding IsEnableText}"
                    Height="25"
                    Width="70"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,220,10,0"
                    Grid.Column="1">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
                </Button.Effect>
            </Button>
            <Button Style="{StaticResource Delete}"
                    IsEnabled="{Binding IsEnable}"
                    Command="{Binding OnDelete}"
                    Content="Удалить"
                    Height="25"
                    Width="70"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,220,85,10"
                    Grid.Column="1">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
                </Button.Effect>
            </Button>
        </Grid>
    </Grid>
</UserControl>
