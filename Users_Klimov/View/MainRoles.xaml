<Page x:Class="Users_Klimov.View.MainRoles"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Users_Klimov.View"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainRoles">

    <Page.Resources>
        <Style TargetType="Button" x:Key="Add">
            <Setter Property="Background" Value="#FF2DD618"/>
            <Setter Property="BorderBrush" Value="#FF2DD618"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Page.Resources>

    <Grid>
        <ListView ItemsSource="{Binding Roles}" HorizontalContentAlignment="Stretch" Margin="0,0,0,45">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <!--<elements:Item DataContext="{Binding}"/>-->
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Button Style="{StaticResource Add}"
            Command="{Binding OnAddRole}"
            Content="Добавить"
            Height="25"
            Width="70"
            VerticalAlignment="Bottom"
            HorizontalAlignment="Right"
            Margin="0,0,10,10"
            Grid.Column="1">
            <Button.Effect>
                <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
            </Button.Effect>
        </Button>
    </Grid>
</Page>
